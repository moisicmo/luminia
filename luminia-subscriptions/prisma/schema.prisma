generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Platform Plans (what luminia sells to businesses) ────────────────────────
model PlatformPlan {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @db.VarChar(100)
  description   String?         @db.VarChar
  price         Decimal         @db.Decimal(15, 4)
  currency      String          @default("BOB") @db.VarChar(3)
  interval      BillingInterval
  intervalCount Int             @default(1) @map("interval_count")
  trialDays     Int             @default(0) @map("trial_days")
  maxProducts   Int?            @map("max_products")
  maxMembers    Int?            @map("max_members")
  maxWarehouses Int?            @map("max_warehouses")
  modules       String[]
  isPublic      Boolean         @default(true) @map("is_public")
  sortOrder     Int             @default(0) @map("sort_order")
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  createdBy     String          @map("created_by") @db.Uuid

  subscriptions PlatformSubscription[]

  @@map("platform_plans")
}

// ─── Platform Subscriptions (business → luminia) ──────────────────────────────
model PlatformSubscription {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String    @unique @map("business_id") @db.Uuid
  planId     String    @map("plan_id") @db.Uuid
  status     SubStatus @default(TRIAL)

  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  nextBillingDate    DateTime  @map("next_billing_date")

  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason") @db.VarChar
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  createdBy    String    @map("created_by") @db.Uuid

  plan     PlatformPlan         @relation(fields: [planId], references: [id])
  payments PlatformSubPayment[]

  @@map("platform_subscriptions")
}

model PlatformSubPayment {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String        @map("subscription_id") @db.Uuid
  orderId        String?       @map("order_id") @db.Uuid
  transactionId  String?       @map("transaction_id") @db.Uuid
  amount         Decimal       @db.Decimal(15, 4)
  currency       String        @default("BOB") @db.VarChar(3)
  status         PaymentStatus @default(PENDING)
  periodStart    DateTime      @map("period_start")
  periodEnd      DateTime      @map("period_end")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")

  subscription PlatformSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("platform_sub_payments")
}

// ─── Business Plans (what businesses sell to their customers) ─────────────────
model Plan {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId    String          @map("business_id") @db.Uuid
  name          String          @db.VarChar(100)
  description   String?         @db.VarChar
  price         Decimal         @db.Decimal(15, 4)
  currency      String          @default("BOB") @db.VarChar(3)
  interval      BillingInterval
  intervalCount Int             @default(1) @map("interval_count")
  trialDays     Int             @default(0) @map("trial_days")
  features      Json?
  maxSlots      Int?            @map("max_slots")
  sortOrder     Int             @default(0) @map("sort_order")
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  createdBy     String          @map("created_by") @db.Uuid
  updatedBy     String?         @map("updated_by") @db.Uuid

  subscriptions Subscription[]

  @@index([businessId])
  @@map("plans")
}

// ─── Subscriptions (customer → business plan) ─────────────────────────────────
model Subscription {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId   String    @map("business_id") @db.Uuid
  planId       String    @map("plan_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  customerName String    @map("customer_name") @db.VarChar(200)
  status       SubStatus @default(PENDING)

  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  nextBillingDate    DateTime  @map("next_billing_date")

  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason") @db.VarChar
  metadata     Json?
  notes        String?   @db.VarChar
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  createdBy    String    @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid

  plan     Plan         @relation(fields: [planId], references: [id])
  payments SubPayment[]

  @@index([businessId, status])
  @@index([customerId])
  @@map("subscriptions")
}

model SubPayment {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String        @map("subscription_id") @db.Uuid
  orderId        String?       @map("order_id") @db.Uuid
  transactionId  String?       @map("transaction_id") @db.Uuid
  amount         Decimal       @db.Decimal(15, 4)
  currency       String        @default("BOB") @db.VarChar(3)
  status         PaymentStatus @default(PENDING)
  periodStart    DateTime      @map("period_start")
  periodEnd      DateTime      @map("period_end")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("sub_payments")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BillingInterval {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum SubStatus {
  TRIAL
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
