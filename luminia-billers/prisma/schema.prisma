generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── SIAT Structure ───────────────────────────────────────────────────────────
// Hierarchy: SiatConfig → BranchOffice → PointSale → Cuis → Cufd → Invoice → InvoiceDetail
// businessId    = external ref to luminia-business (Business)
// branchId      = external ref to luminia-business (Branch)
// pointOfSaleId = external ref to luminia-business (PointOfSale)
// referenceId   = external ref to luminia-orders   (Order)

// ─── SIAT config per business ─────────────────────────────────────────────────
// One record per business. Stores the environment (TEST/PRODUCTION) and main
// economic activity to avoid querying it on every invoice.

model SiatConfig {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId       String          @unique @map("business_id") @db.Uuid
  environment      EnvironmentSiat @default(TEST)
  nit              String          @db.VarChar(20)       // tax ID of the issuer
  socialReason     String          @map("social_reason") @db.VarChar(500)
  mainActivityCode Int             @map("main_activity_code") // main SIAT economic activity code
  isOnline         Boolean         @default(true) @map("is_online")  // true=online, false=contingencia
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
  createdBy        String          @map("created_by") @db.Uuid
  updatedBy        String?         @map("updated_by") @db.Uuid

  @@map("siat_configs")
}

// ─── Branch office (SIAT registration) ───────────────────────────────────────

model BranchOffice {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId         String         @map("business_id") @db.Uuid
  branchId           String?        @map("branch_id") @db.Uuid     // ref luminia-business Branch
  branchOfficeSiatId Int            @map("branch_office_siat_id")
  name               String         @db.VarChar(50)
  description        String         @db.VarChar
  active             Boolean        @default(true)
  city               String?        @db.VarChar
  phone              String?        @db.VarChar(15)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @default(now()) @updatedAt @map("updated_at")
  createdBy          String         @map("created_by") @db.Uuid
  updatedBy          String?        @map("updated_by") @db.Uuid

  pointSales    PointSale[]
  events        Event[]
  wrappers      Wrapper[]
  wrapperEvents WrapperEvent[]

  @@map("branch_offices")
}

model PointSale {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchOfficeId  String         @map("branch_office_id") @db.Uuid
  pointOfSaleId   String?        @map("point_of_sale_id") @db.Uuid  // ref luminia-business PointOfSale
  pointSaleSiatId Int            @map("point_sale_siat_id")
  name            String         @db.VarChar(50)
  description     String         @db.VarChar
  active          Boolean        @default(true)
  pointSaleTypeId String?        @map("point_sale_type_id") @db.Uuid

  branchOffice  BranchOffice   @relation(fields: [branchOfficeId], references: [id])
  pointSaleType PointSaleType? @relation(fields: [pointSaleTypeId], references: [id])
  cuis          Cuis[]
  events        Event[]
  wrappers      Wrapper[]
  wrapperEvents WrapperEvent[]

  @@map("point_sales")
}

// ─── CUIS / CUFD ──────────────────────────────────────────────────────────────
// CUIS = Código Único de Inicio de Sistema (authorization code per point of sale)
// CUFD = Código Único de Facturación Diaria  (daily billing code)

model Cuis {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @db.VarChar(20)    // the CUIS value from SIAT
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  active      Boolean   @default(true)
  pointSaleId String    @map("point_sale_id") @db.Uuid

  pointSale PointSale @relation(fields: [pointSaleId], references: [id])
  cufds     Cufd[]

  @@map("cuis")
}

model Cufd {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @db.VarChar(100)   // the CUFD value from SIAT
  controlCode String    @map("control_code") @db.VarChar(20)
  address     String    @db.VarChar
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  active      Boolean   @default(true)
  cuisId      String    @map("cuis_id") @db.Uuid

  cuis     Cuis      @relation(fields: [cuisId], references: [id])
  invoices Invoice[]

  @@map("cufds")
}

// ─── Invoice ──────────────────────────────────────────────────────────────────

model Invoice {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId           String          @map("business_id") @db.Uuid          // ref luminia-business
  // Link to the sale that originated this invoice
  referenceType        InvoiceRefType? @map("reference_type")
  referenceId          String?         @map("reference_id") @db.Uuid         // Order.id or other
  // SIAT identifiers
  invoiceNumber        Int             @map("invoice_number")
  cuf                  String          @db.VarChar(70)
  cafc                 String?         @db.VarChar
  receptionCode        String?         @map("reception_code") @db.VarChar(50)
  broadcastDate        DateTime        @map("broadcast_date")
  // Issuer (snapshots at time of billing — immutable)
  issuerNit            String          @map("issuer_nit") @db.VarChar(20)
  issuerName           String          @map("issuer_name") @db.VarChar(500)
  // Buyer
  buyerNit             String          @map("buyer_nit") @db.VarChar(20)
  buyerName            String          @map("buyer_name") @db.VarChar(500)
  buyerComplement      String?         @map("buyer_complement") @db.VarChar(5)  // NIT complement
  buyerEmail           String?         @map("buyer_email") @db.VarChar(200)
  // Totals
  totalAmount          Decimal         @map("total_amount") @db.Decimal(15, 4)
  vatableAmount        Decimal         @map("vatable_amount") @db.Decimal(15, 4) // subject to VAT (IVA)
  iceAmount            Decimal         @default(0) @map("ice_amount") @db.Decimal(15, 4)
  iehdAmount           Decimal         @default(0) @map("iehd_amount") @db.Decimal(15, 4)
  additionalDiscount   Decimal         @default(0) @map("additional_discount") @db.Decimal(15, 4)
  // XML/JSON content
  invoiceXml           String          @map("invoice_xml") @db.Text
  invoiceHash          String          @map("invoice_hash") @db.VarChar(70)
  invoiceJson          String          @map("invoice_json") @db.Text
  // Status and modality
  status               InvoiceStatus   @default(PENDING)
  siatStatus           SiatStatus?     @map("siat_status")
  modality             ModalitySiat
  // SIAT FK
  cufdId               String          @map("cufd_id") @db.Uuid
  sectorDocumentTypeId String          @map("sector_document_type_id") @db.Uuid
  broadcastTypeId      String          @map("broadcast_type_id") @db.Uuid
  invoiceTypeId        String          @map("invoice_type_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @default(now()) @updatedAt @map("updated_at")
  createdBy            String          @map("created_by") @db.Uuid
  updatedBy            String?         @map("updated_by") @db.Uuid

  cufd                 Cufd                  @relation(fields: [cufdId], references: [id])
  sectorDocumentType   SectorDocumentType    @relation(fields: [sectorDocumentTypeId], references: [id])
  broadcastType        BroadcastType         @relation(fields: [broadcastTypeId], references: [id])
  invoiceType          InvoiceType           @relation(fields: [invoiceTypeId], references: [id])
  details              InvoiceDetail[]
  invoiceRequest       InvoiceRequest?
  invoiceBatches       InvoiceBatch[]
  invoiceWrapperEvents InvoiceWrapperEvent[]
  pendingToFix         PendingToFix?
  automaticFix         AutomaticInvoiceFix?
  cancellation         InvoiceCancellation?

  @@index([businessId, status])
  @@index([broadcastDate, status])
  @@index([referenceId])
  @@map("invoices")
}

// Invoice line items — required to build the SIAT XML
// Each sold product/service with its SIN product code, unit, price, etc.
model InvoiceDetail {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId         String  @map("invoice_id") @db.Uuid
  economicActivity  String  @map("economic_activity") @db.VarChar(10)
  sinProductCode    Int     @map("sin_product_code")            // SIN catalog code from SIAT
  productCode       String  @map("product_code") @db.VarChar(20) // business internal code
  description       String  @db.VarChar(1000)
  quantity          Decimal @db.Decimal(15, 4)
  measurementUnit   Int     @map("measurement_unit")            // siatId of MeasurementUnit
  unitPrice         Decimal @map("unit_price") @db.Decimal(15, 4)
  discountAmount    Decimal @default(0) @map("discount_amount") @db.Decimal(15, 4)
  subtotal          Decimal @db.Decimal(15, 4)                  // qty * unitPrice - discount
  // Optional SIAT fields
  imeiNumber        String? @map("imei_number") @db.VarChar(20) // for mobile devices
  originCountryCode Int?    @map("origin_country_code")         // siatId of OriginCountry

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_details")
}

// Cancellation record — who cancelled, when, and the SIAT reason code
model InvoiceCancellation {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId            String      @unique @map("invoice_id") @db.Uuid
  cancellationReasonId String      @map("cancellation_reason_id") @db.Uuid // ref CancellationReason
  receptionCode        String?     @map("reception_code") @db.VarChar(50)
  siatStatus           SiatStatus? @map("siat_status")
  cancelledAt          DateTime    @map("cancelled_at")
  cancelledBy          String      @map("cancelled_by") @db.Uuid
  notes                String?     @db.VarChar
  createdAt            DateTime    @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_cancellations")
}

model InvoiceRequest {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestDate  DateTime           @map("request_date")
  responseDate DateTime?          @map("response_date")
  businessId   String?            @map("business_id") @db.Uuid
  invoiceId    String?            @unique @map("invoice_id") @db.Uuid
  request      String             @db.Text
  cuf          String?            @db.VarChar(70)
  observation  String?            @db.VarChar(500)
  response     Boolean?
  elapsedTime  BigInt?            @map("elapsed_time")
  type         InvoiceRequestType
  errorChecked Boolean            @default(false) @map("error_checked")

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@map("invoice_requests")
}

model InvoiceBatch {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber        BigInt           @map("invoice_number")
  broadcastDate        DateTime         @map("broadcast_date")
  invoiceJson          String           @map("invoice_json") @db.Text
  responseMessage      String?          @map("response_message") @db.VarChar
  invoiceId            String?          @map("invoice_id") @db.Uuid
  batchId              String?          @map("batch_id") @db.Uuid
  sectorDocumentTypeId String?          @map("sector_document_type_id") @db.Uuid

  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  batch           Batch?           @relation(fields: [batchId], references: [id])
  invoiceWrappers InvoiceWrapper[]

  @@map("invoice_batches")
}

model InvoiceWrapper {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileNumber      Int           @map("file_number")
  responseMessage String?       @map("response_message") @db.VarChar
  status          WrapperStatus
  invoiceBatchId  String?       @map("invoice_batch_id") @db.Uuid
  wrapperId       String?       @map("wrapper_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy       String        @map("created_by") @db.Uuid
  updatedBy       String?       @map("updated_by") @db.Uuid

  invoiceBatch InvoiceBatch? @relation(fields: [invoiceBatchId], references: [id])
  wrapper      Wrapper?      @relation(fields: [wrapperId], references: [id])

  @@map("invoice_wrappers")
}

model InvoiceWrapperEvent {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileNumber      Int           @map("file_number")
  responseMessage String?       @map("response_message") @db.VarChar
  status          WrapperStatus
  invoiceId       String?       @map("invoice_id") @db.Uuid
  wrapperEventId  String?       @map("wrapper_event_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy       String        @map("created_by") @db.Uuid
  updatedBy       String?       @map("updated_by") @db.Uuid

  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  wrapperEvent WrapperEvent? @relation(fields: [wrapperEventId], references: [id])

  @@map("invoice_wrapper_events")
}

model PendingToFix {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId  String        @unique @map("invoice_id") @db.Uuid
  businessId String        @map("business_id") @db.Uuid
  eventId    String?       @map("event_id") @db.Uuid
  action     PendingAction
  counter    Int           @default(0)
  failReason String?       @map("fail_reason") @db.VarChar(2000)
  status     PendingStatus
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy  String        @map("created_by") @db.Uuid
  updatedBy  String?       @map("updated_by") @db.Uuid

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  event   Event?  @relation(fields: [eventId], references: [id])

  @@map("pending_to_fixes")
}

model AutomaticInvoiceFix {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId       String        @unique @map("invoice_id") @db.Uuid
  oldStatus       InvoiceStatus @map("old_status")
  newStatus       InvoiceStatus @map("new_status")
  siatStatus      SiatStatus    @map("siat_status")
  siatObservation String        @map("siat_observation") @db.VarChar
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy       String        @map("created_by") @db.Uuid
  updatedBy       String?       @map("updated_by") @db.Uuid

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("automatic_invoice_fixes")
}

model CheckInvoice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  position  BigInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("check_invoices")
}

// ─── Events & Wrappers ────────────────────────────────────────────────────────

model Event {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cufdEvent          String          @map("cufd_event") @db.VarChar(100)
  startDate          DateTime        @map("start_date")
  endDate            DateTime        @map("end_date")
  receptionCode      Int?            @map("reception_code")
  description        String          @db.VarChar(500)
  active             Boolean         @default(true)
  cafc               String?         @db.VarChar
  branchOfficeId     String          @map("branch_office_id") @db.Uuid
  significantEventId String          @map("significant_event_id") @db.Uuid
  pointSaleId        String          @map("point_sale_id") @db.Uuid
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at")
  createdBy          String          @map("created_by") @db.Uuid
  updatedBy          String?         @map("updated_by") @db.Uuid

  branchOffice     BranchOffice    @relation(fields: [branchOfficeId], references: [id])
  pointSale        PointSale       @relation(fields: [pointSaleId], references: [id])
  significantEvent SignificantEvent @relation(fields: [significantEventId], references: [id])
  wrapperEvents    WrapperEvent[]
  pendingToFixes   PendingToFix[]

  @@map("events")
}

model Wrapper {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cufdEvent            String             @map("cufd_event") @db.VarChar(100)
  startDate            DateTime           @map("start_date")
  endDate              DateTime           @map("end_date")
  receptionCode        String             @map("reception_code") @db.VarChar
  status               WrapperStatus
  scheduleSettingId    String?            @map("schedule_setting_id") @db.Uuid
  branchOfficeId       String             @map("branch_office_id") @db.Uuid
  pointSaleId          String             @map("point_sale_id") @db.Uuid
  sectorDocumentTypeId String             @map("sector_document_type_id") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at")
  createdBy            String             @map("created_by") @db.Uuid
  updatedBy            String?            @map("updated_by") @db.Uuid

  scheduleSetting    ScheduleSetting?   @relation(fields: [scheduleSettingId], references: [id])
  branchOffice       BranchOffice       @relation(fields: [branchOfficeId], references: [id])
  pointSale          PointSale          @relation(fields: [pointSaleId], references: [id])
  sectorDocumentType SectorDocumentType @relation(fields: [sectorDocumentTypeId], references: [id])
  invoiceWrappers    InvoiceWrapper[]

  @@map("wrappers")
}

model WrapperEvent {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receptionCode        String             @map("reception_code") @db.VarChar
  status               WrapperStatus
  eventId              String             @map("event_id") @db.Uuid
  branchOfficeId       String             @map("branch_office_id") @db.Uuid
  pointSaleId          String             @map("point_sale_id") @db.Uuid
  sectorDocumentTypeId String             @map("sector_document_type_id") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at")
  createdBy            String             @map("created_by") @db.Uuid
  updatedBy            String?            @map("updated_by") @db.Uuid

  event                Event                @relation(fields: [eventId], references: [id])
  branchOffice         BranchOffice         @relation(fields: [branchOfficeId], references: [id])
  pointSale            PointSale            @relation(fields: [pointSaleId], references: [id])
  sectorDocumentType   SectorDocumentType   @relation(fields: [sectorDocumentTypeId], references: [id])
  invoiceWrapperEvents InvoiceWrapperEvent[]

  @@map("wrapper_events")
}

model WrapperLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wrapperType Int      @map("wrapper_type")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  response    Boolean?
  description String?  @db.VarChar
  businessId  String   @map("business_id") @db.Uuid

  @@map("wrapper_logs")
}

// ─── Batch ────────────────────────────────────────────────────────────────────

model Batch {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receptionCode  String         @map("reception_code") @db.VarChar(50)
  date           DateTime
  status         BatchStatus
  businessId     String         @map("business_id") @db.Uuid

  invoiceBatches InvoiceBatch[]

  @@map("batches")
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model ScheduleSetting {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cronDate    String    @map("cron_date") @db.VarChar(50)
  description String    @db.VarChar
  active      Boolean   @default(true)
  businessId  String    @map("business_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  wrappers Wrapper[]

  @@map("schedule_settings")
}

model SyncSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syncType    Int      @map("sync_type")
  cronDate    String   @map("cron_date") @db.VarChar
  description String   @db.VarChar
  active      Boolean  @default(true)
  businessId  String   @map("business_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy   String   @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid

  @@map("sync_settings")
}

model SyncLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syncType    Int       @map("sync_type")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  response    Boolean?
  description String?   @db.VarChar
  businessId  String    @map("business_id") @db.Uuid

  @@map("sync_logs")
}

// ─── Digital signature ────────────────────────────────────────────────────────

model Signature {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  certificate String    @db.Text
  privateKey  String    @map("private_key") @db.Text
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  active      Boolean   @default(true)
  businessId  String    @map("business_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  @@map("signatures")
}

// ─── SIAT product/service catalog ─────────────────────────────────────────────

model ProductService {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siatId           Int               @map("siat_id")
  activityCode     Int               @map("activity_code")
  description      String            @db.VarChar(1000)
  active           Boolean           @default(true)
  businessId       String            @map("business_id") @db.Uuid

  approvedProducts ApprovedProduct[]

  @@map("product_services")
}

model ApprovedProduct {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productCode       String          @map("product_code") @db.VarChar(20)
  description       String          @db.VarChar
  businessId        String          @map("business_id") @db.Uuid
  productServiceId  String          @map("product_service_id") @db.Uuid
  measurementUnitId String          @map("measurement_unit_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at")
  createdBy         String          @map("created_by") @db.Uuid
  updatedBy         String?         @map("updated_by") @db.Uuid

  productService  ProductService  @relation(fields: [productServiceId], references: [id])
  measurementUnit MeasurementUnit @relation(fields: [measurementUnitId], references: [id])

  @@map("approved_products")
}

// ─── SIAT lookup tables (synced from SIAT per business) ───────────────────────

model Activity {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siatId       Int     @map("siat_id")
  description  String  @db.VarChar
  activityType String  @map("activity_type") @db.VarChar(10)
  active       Boolean @default(true)
  businessId   String  @map("business_id") @db.Uuid

  @@map("activities")
}

model BroadcastType {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siatId      Int       @map("siat_id")
  description String    @db.VarChar
  active      Boolean   @default(true)
  businessId  String    @map("business_id") @db.Uuid

  invoices Invoice[]

  @@map("broadcast_types")
}

model InvoiceType {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siatId      Int       @map("siat_id")
  description String    @db.VarChar
  active      Boolean   @default(true)
  businessId  String    @map("business_id") @db.Uuid

  invoices Invoice[]

  @@map("invoice_types")
}

