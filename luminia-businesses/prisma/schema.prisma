// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model SystemAssignment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  systemId   String   @map("system_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy  String   @map("created_by")
  updatedBy  String?  @map("updated_by")
  business   Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, systemId])
  @@map("system_assignments")
}

model Business {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId      String       @map("owner_id") @db.Uuid
  name         String       @db.VarChar
  businessType BusinessType @default(TIENDA) @map("business_type")
  url          String?      @db.VarChar
  taxId        String?      @map("tax_id") @db.VarChar
  logo         String?      @db.VarChar
  active       Boolean      @default(true)

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")
  createdBy         String             @map("created_by") @db.Uuid
  updatedBy         String?            @map("updated_by") @db.Uuid
  branches          Branch[]
  systemAssignments SystemAssignment[]
  members           BusinessMember[]
  roles             BusinessRole[]
  customers         BusinessCustomer[]
  invitations       BusinessInvitation[]

  @@map("businesses")
}

model BusinessRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  name        String   @db.VarChar
  description String?  @db.VarChar
  isSystem    Boolean  @default(false) @map("is_system") // created automatically, cannot be deleted
  permissions String[] // e.g. ["ventas:crear", "productos:ver"]

  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at")
  createdBy String           @map("created_by") @db.Uuid
  updatedBy String?          @map("updated_by") @db.Uuid
  business    Business             @relation(fields: [businessId], references: [id])
  members     BusinessMember[]
  invitations BusinessInvitation[]

  @@map("business_roles")
}

model BusinessMember {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid   // personId from luminia-users
  role          MemberRole  @default(MEMBER)
  roleId        String?     @map("role_id") @db.Uuid   // FK to BusinessRole (null for OWNER)
  branchIds     String[]    @map("branch_ids") @db.Uuid // sucursales asignadas (vacío = todas)
  pointOfSaleId String?     @map("point_of_sale_id") @db.Uuid // POS asignado (cajeros)
  active        Boolean     @default(true)

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy    String        @map("created_by") @db.Uuid
  updatedBy    String?       @map("updated_by") @db.Uuid
  business     Business      @relation(fields: [businessId], references: [id])
  businessRole BusinessRole? @relation(fields: [roleId], references: [id])

  @@unique([businessId, userId])
  @@index([userId])
  @@map("business_members")
}

// ─── Clientes por negocio (fuente única, no se duplica en cada microservicio) ─
// personId es opcional: permite clientes walk-in sin cuenta en la plataforma.
// Cuando un cliente se registra, se vincula retroactivamente por taxId/phone.

model BusinessCustomer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  personId   String?  @map("person_id") @db.Uuid // null para clientes sin cuenta
  name       String   @db.VarChar(200)
  lastName   String?  @map("last_name") @db.VarChar(200)
  taxId      String?  @map("tax_id") @db.VarChar(20)
  phone      String?  @db.VarChar(20)
  email      String?  @db.VarChar(100)
  address    String?  @db.VarChar
  active     Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  business  Business @relation(fields: [businessId], references: [id])

  @@index([businessId, active])
  @@index([personId])
  @@map("business_customers")
}

// ─── Invitaciones al equipo (tipo GitHub) ──────────────────────────────────────
// Se envía invitación por email/teléfono. Si el invitado ya tiene cuenta → se
// vincula directo. Si no → queda PENDING hasta que se registre y se auto-acepta.

model BusinessInvitation {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String           @map("business_id") @db.Uuid
  email      String?          @db.VarChar(100)
  phone      String?          @db.VarChar(20)
  roleId     String           @map("role_id") @db.Uuid
  branchIds  String[]         @map("branch_ids") @db.Uuid
  status     InvitationStatus @default(PENDING)
  token      String           @unique @db.VarChar(255)
  expiresAt  DateTime         @map("expires_at")

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy    String        @map("created_by") @db.Uuid
  business     Business      @relation(fields: [businessId], references: [id])
  businessRole BusinessRole  @relation(fields: [roleId], references: [id])

  @@index([email])
  @@index([phone])
  @@index([token])
  @@map("business_invitations")
}

model Branch {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId   String  @map("business_id") @db.Uuid
  code         String? @db.VarChar
  name         String  @db.VarChar
  region       String  @db.VarChar
  address      String? @db.VarChar
  municipality String? @db.VarChar
  phone        String? @db.VarChar
  latitude     Float?
  longitude    Float?
  openingHours String? @map("opening_hours") @db.VarChar
  active       Boolean @default(true)

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  createdBy    String        @map("created_by")
  updatedBy    String?       @map("updated_by")
  business     Business      @relation(fields: [businessId], references: [id])
  pointsOfSale PointOfSale[]

  @@map("branches")
}

model PointOfSale {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  code      String?   @db.VarChar
  name      String    @db.VarChar
  paperSize PaperSize @default(LETTER) @map("paper_size")
  active    Boolean   @default(true)

  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at")
  createdBy String               @map("created_by")
  updatedBy String?              @map("updated_by")
  branch    Branch               @relation(fields: [branchId], references: [id])
  sessions  CashRegisterSession[]

  @@map("points_of_sale")
}

// ─── Apertura/Cierre de caja ─────────────────────────────────────────────────
// Cada sesión representa un turno: apertura con monto inicial → cierre con
// totales y diferencia. cashierId = personId del cajero (luminia-users).

model CashRegisterSession {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId      String             @map("business_id") @db.Uuid
  pointOfSaleId   String             @map("point_of_sale_id") @db.Uuid
  cashierId       String             @map("cashier_id") @db.Uuid        // personId del cajero
  status          CashSessionStatus  @default(OPEN)
  openingAmount   Decimal            @map("opening_amount") @db.Decimal(15, 4)
  closingAmount   Decimal?           @map("closing_amount") @db.Decimal(15, 4)
  expectedAmount  Decimal?           @map("expected_amount") @db.Decimal(15, 4)
  difference      Decimal?           @db.Decimal(15, 4)                         // closing - expected
  currency        String             @default("BOB") @db.VarChar(3)
  openedAt        DateTime           @default(now()) @map("opened_at")
  closedAt        DateTime?          @map("closed_at")
  notes           String?            @db.VarChar
  createdBy       String             @map("created_by") @db.Uuid
  updatedBy       String?            @map("updated_by") @db.Uuid

  pointOfSale PointOfSale @relation(fields: [pointOfSaleId], references: [id])

  @@index([businessId, status])
  @@index([cashierId])
  @@map("cash_register_sessions")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum PaperSize {
  LETTER   // Carta 215.9×279.4 mm
  ROLL_80  // Rollo POS 80 mm
  ROLL_58  // Rollo POS 58 mm
}

enum MemberRole {
  OWNER  // Dueño — control total, no necesita BusinessRole
  MEMBER // Todos los demás — sus permisos vienen de BusinessRole
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum BusinessType {
  ADMINISTRACION
  SERVICIO
  TIENDA
  RESTAURANT
  HOTEL
  CAPACITACION
  INSTITUTO
  COLEGIO
  TRANSPORTE
  SALUD
  ENTRETENIMIENTO
  ECOMMERCE
  CONSULTORIA
  GIMNASIO
  VETERINARIA
  BARBERIA
  SPA
  DENTISTA
  PSICOLOGO
  AGENCIA_TURISTICA
  INMOBILIARIA
  SEGURO
  FREELANCER
  LIBRERIA
}
