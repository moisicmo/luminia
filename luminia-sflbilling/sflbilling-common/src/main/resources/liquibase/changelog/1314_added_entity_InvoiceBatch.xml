<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd">

    <changeSet id="1314-1" author="jhipster">
        <createSequence sequenceName="invoice_batch_seq" startValue="1050" incrementBy="50"/>
        <createTable tableName="invoice_batch">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="invoice_number" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="broadcast_date" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="invoice_json" type="${clobType}">
                <constraints nullable="false"/>
            </column>
            <column name="response_message" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="invoice_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="batch_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="sector_document_type_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <dropDefaultValue tableName="invoice_batch" columnName="broadcast_date" columnDataType="datetime"/>
    </changeSet>
</databaseChangeLog>
