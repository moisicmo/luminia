<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="1315-2" author="jhipster">
        <createTable tableName="automatic_invoice_fix">
            <column name="invoice_id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="old_status" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="new_status" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="siat_status" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="siat_observation" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="timestamp"/>
            <column name="last_modified_by" type="varchar(50)"/>
            <column name="last_modified_date" type="timestamp"/>
        </createTable>
        <addForeignKeyConstraint baseColumnNames="invoice_id"
                                 baseTableName="automatic_invoice_fix"
                                 constraintName="fk_automatic_invoice_fix_invoice_id"
                                 referencedColumnNames="id"
                                 referencedTableName="invoice"/>
    </changeSet>
</databaseChangeLog>
