<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="1303-1" author="jhipster">
        <createSequence sequenceName="cufd_seq" startValue="1050" incrementBy="50"/>
        <createTable tableName="cufd">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cufd" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="control_code" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="address" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="cuis_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <dropDefaultValue tableName="cufd" columnName="start_date" columnDataType="datetime"/>
        <dropDefaultValue tableName="cufd" columnName="end_date" columnDataType="datetime"/>
    </changeSet>
</databaseChangeLog>
