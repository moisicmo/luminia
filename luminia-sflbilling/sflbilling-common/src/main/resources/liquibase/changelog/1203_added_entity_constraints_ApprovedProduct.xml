<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd">

    <changeSet id="1203-2" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="company_id"
                                 baseTableName="approved_product"
                                 constraintName="fk_approved_product_company_id"
                                 referencedColumnNames="id"
                                 referencedTableName="company"/>

        <addForeignKeyConstraint baseColumnNames="product_service_id"
                                 baseTableName="approved_product"
                                 constraintName="fk_approved_product_product_service_id"
                                 referencedColumnNames="id"
                                 referencedTableName="product_service"/>

        <addForeignKeyConstraint baseColumnNames="measurement_unit_id"
                                 baseTableName="approved_product"
                                 constraintName="fk_approved_product_measurement_unit_id"
                                 referencedColumnNames="id"
                                 referencedTableName="measurement_unit"/>
    </changeSet>
</databaseChangeLog>
